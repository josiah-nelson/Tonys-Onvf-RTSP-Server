# Tonys ONVIF RTSP Server — Environment Configuration
# Copy this file to .env and modify as needed.
# All values shown are the defaults used when no .env file is present.

# === Server Ports ===
WEB_UI_PORT=5552
MEDIAMTX_PORT=8554
MEDIAMTX_API_PORT=9997
ONVIF_BASE_PORT=8001

# === Thread Configuration ===
WSGI_MAX_WORKERS=20
# AI_TORCH_THREADS=       # Auto-detected if empty: min(4, cpu_count // 2)

# === AI Inference Defaults ===
AI_DEFAULT_MODEL=yolov8n.pt
AI_INFERENCE_FRAME_WIDTH=640
AI_COOLDOWN_SECONDS=5.0
AI_TARGET_INTERVAL=0.50

# === Video Encoding (GridFusion) ===
GF_VIDEO_BITRATE=2500k
GF_VIDEO_BUFSIZE=5000k
GF_ENCODER_PRESET=ultrafast
